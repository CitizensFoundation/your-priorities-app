# ==========================================
# БАЗОВЫЕ НАСТРОЙКИ ХОСТА И ДОМЕНА
# ==========================================
DOMAIN_NAME=nation.governmentussr.com
FULL_HOSTNAME=nation.governmentussr.com
CERTBOT_CERT_FOLDER=nation.governmentussr.com
NODE_ENV=production
DEFAULT_LOCALE=ru
DISABLE_FORCE_HTTPS=true
USING_NGINX_PROXY=true
LOGIN_CALLBACK_CUSTOM_HOSTNAME=nation.governmentussr.com
YOUR_PRIORITIES_LISTEN_HOST=0.0.0.0

# ==========================================
# БАЗА ДАННЫХ И КЭШ
# ==========================================
POSTGRES_USER=yrpri_db_user
POSTGRES_PASSWORD=test_pass_123
POSTGRES_DB=yrpri_production
DATABASE_URL=postgresql://yrpri_db_user:test_pass_123@postgres:5432/yrpri_production
REDIS_URL=redis://redis:6379

# ==========================================
# СЕКРЕТЫ ПРИЛОЖЕНИЯ
# ==========================================
SESSION_SECRET=test_secret_321

# ==========================================
# ИНТЕГРАЦИЯ KEYCLOAK SSO (OIDC)
# ==========================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=test_kc_admin
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=test_kc_db
OIDC_ENABLED=true
OIDC_CLIENT_ID=yrpri-nation-client
OIDC_CLIENT_SECRET=test_oidc_secret
OIDC_DISCOVERY_URL=https://auth.governmentussr.com/realms/ussr-ecosystem/.well-known/openid-configuration
OIDC_CALLBACK_URL=https://nation.governmentussr.com/api/users/auth/oidc/callback
OIDC_ISSUER=https://auth.governmentussr.com/realms/ussr-ecosystem
OIDC_AUTHORIZATION_URL=https://auth.governmentussr.com/realms/ussr-ecosystem/protocol/openid-connect/auth
OIDC_TOKEN_URL=https://auth.governmentussr.com/realms/ussr-ecosystem/protocol/openid-connect/token
OIDC_USERINFO_URL=https://auth.governmentussr.com/realms/ussr-ecosystem/protocol/openid-connect/userinfo

# ==========================================
# НАСТРОЙКИ SMTP (Brevo)
# ==========================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=a2ef37001@smtp-brevo.com
SMTP_PASSWORD=test_smtp_pass
SMTP_SECURE=false
EMAIL_CONFIG_FROM_ADDRESS=noreply@nation.governmentussr.com
EMAIL_CONFIG_FROM_NAME="Nation"
EMAIL_CONFIG_URL=https://nation.governmentussr.com

# ==========================================
# ВНУТРЕННЕЕ ХРАНИЛИЩЕ ФАЙЛОВ (MINIO)
# ==========================================
MINIO_DOMAIN=minio.nation.governmentussr.com
MINIO_ROOT_USER=yrpri_admin
MINIO_ROOT_PASSWORD=test_minio_pass
AWS_ACCESS_KEY_ID=yrpri_admin
AWS_SECRET_ACCESS_KEY=test_minio_pass
MINIO_ACCESS_KEY=yrpri_admin
MINIO_SECRET_KEY=test_minio_pass
S3_ENDPOINT=http://minio:9000
S3_BUCKET=minio.yrpri.production
S3_ATTACHMENTS_BUCKET=minio.yrpri.attachments
S3_REPORTS_BUCKET=minio.yrpri.reports
S3_VIDEO_THUMBNAIL_BUCKET=minio-video-thumbnails
S3_VIDEO_PUBLIC_BUCKET=minio-video-public
S3_VIDEO_UPLOAD_BUCKET=minio-video-upload
S3_AUDIO_UPLOAD_BUCKET=minio-audio-upload
S3_AUDIO_PUBLIC_BUCKET=minio-audio-public
S3_FORCE_PATH_STYLE=true

# ==========================================
# ОСТАЛЬНЫЕ НАСТРОЙКИ
# ==========================================
YP_INDEX_APP_NAME="Нация"
YP_INDEX_DESCRIPTION="Платформа"
USE_YOUR_PRIORITIES_ENCODER=true
NEW_RELIC_LOG=stdout
NEW_RELIC_NO_CONFIG_FILE=true
DISABLE_PG_SSL=true
YP_FORCE_DOMAIN_NAME=nation.governmentussr.com
ADMIN_PASSWORD=change_me_to_real_password_123
